# Docker: postgresql://postgres:postgres@localhost:5432/corapak_quotes
# Homebrew (Mac): use your Mac username, no password:
#   postgresql://YOUR_USERNAME@localhost:5432/corapak_quotes
#   e.g. postgresql://richardli@localhost:5432/corapak_quotes
DATABASE_URL=postgresql://localhost:5432/corapak_quotes
BACKEND_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

